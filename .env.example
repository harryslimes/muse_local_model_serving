MUSE_BACKEND_DIR=../muse_backend
MUSE_SVELTE_DIR=../muse_svelte

# Hugging Face token for gated model downloads when needed.
# HF_TOKEN=hf_xxx

ENABLE_BACKEND=true
ENABLE_FRONTEND=true
ENABLE_IMAGE_SERVER=false
ENABLE_LLM_SERVER=true
ENABLE_VOICE_STT=true
ENABLE_VOICE_TTS=true

# Mac local LLM backend:
# - mlx       uses Qwen3.5-4B MLX server on http://127.0.0.1:12434
# - llama.cpp uses a GGUF model via llama-server on http://127.0.0.1:12436
# - gemma     uses gemma-4-26B-A4B-it MLX server on http://127.0.0.1:12437
LOCAL_LLM_SERVER_MODE=mlx

# Required only when LOCAL_LLM_SERVER_MODE=llama.cpp
# LOCAL_LLAMA_MODEL_PATH=/absolute/path/to/model.gguf

MUSE_BACKEND_PORT=8100
MUSE_FRONTEND_PORT=5100
