# Copy to .env and customize.

# ---------------------------------------------------------------------------
# Services to enable (true/false). CLI flags like --with-voice-tts override.
# ---------------------------------------------------------------------------
ENABLE_BACKEND=true
ENABLE_FRONTEND=true
ENABLE_IMAGE_SERVER=false
ENABLE_LLM_SERVER=false
ENABLE_VOICE_STT=false
ENABLE_VOICE_TTS=false
ENABLE_TOOL_SERVER=false

# ---------------------------------------------------------------------------
# Paths to sibling project directories (needed when ENABLE_BACKEND/FRONTEND).
# Relative to this directory or absolute.
# ---------------------------------------------------------------------------
# MUSE_BACKEND_DIR=../muse_backend
# MUSE_SVELTE_DIR=../muse_svelte

# ---------------------------------------------------------------------------
# Hugging Face token for gated model downloads
# ---------------------------------------------------------------------------
HF_TOKEN=hf_your_token_here

# ---------------------------------------------------------------------------
# Voice service settings
# ---------------------------------------------------------------------------
# KOKORO_PROVIDER=gpu          # "gpu" (default) or "cpu"
# KOKORO_PORT=4125
# KOKORO_TTS_URL=http://127.0.0.1:4125
# PARAKEET_STT_URL=http://127.0.0.1:4124
# CHATTERBOX_TTS_URL=http://127.0.0.1:4123

# ---------------------------------------------------------------------------
# Tool server settings (SearXNG + crawl4ai)
# ---------------------------------------------------------------------------
# TOOL_SERVER_URL=http://127.0.0.1:4130
# TOOL_SERVER_PORT=4130
# SEARXNG_PORT=8888
# CRAWL_MAX_CHARS=8000
# SEARCH_MAX_RESULTS=5

# ---------------------------------------------------------------------------
# LLM / Image server settings
# ---------------------------------------------------------------------------
# LOCAL_LLM_SERVER_MODE=qwen35   # "qwen35" (llama.cpp GGUF, default), "vllm" (vLLM GPTQ), "atlas-nvfp4"
# FLUX2_KLEIN_PROFILE=9b-fp8
# DOCKER_MODE=true
# LLAMA_EXTRA_FLAGS="--swa-full -np 1"
# SLOT_SAVE_PATH=/runtime/slot-cache

# ---------------------------------------------------------------------------
# vLLM server settings (when LOCAL_LLM_SERVER_MODE=vllm)
# ---------------------------------------------------------------------------
# VLLM_IMAGE=dgx-vllm:latest
# VLLM_MODEL=Qwen/Qwen3.5-35B-A3B-GPTQ-Int4
# VLLM_SERVED_MODEL_NAME=Qwen3.5-35B-A3B
# VLLM_MAX_MODEL_LEN=32768
# VLLM_GPU_MEM_UTIL=0.90
