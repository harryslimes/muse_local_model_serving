# Paths to sibling project directories (relative to this directory or absolute).
MUSE_BACKEND_DIR=../../muse_backend
MUSE_SVELTE_DIR=../../muse_svelte

# Hugging Face token for gated model downloads (for example black-forest-labs/*)
#HF_TOKEN=your_token_here
HF_TOKEN=your_token_here
# Optional defaults for this local server wrapper:
# FLUX2_KLEIN_PROFILE=9b-fp8
# DOCKER_MODE=true
LOCAL_LLM_SERVER_MODE=vllm
LLAMA_EXTRA_FLAGS="--swa-full -np 1"
MODEL_ROOT=/home/jc2301/models
ENABLE_BACKEND=true
ENABLE_FRONTEND=true
ENABLE_IMAGE_SERVER=false
ENABLE_LLM_SERVER=true
ENABLE_VOICE_STT=true
ENABLE_VOICE_TTS=true